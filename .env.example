# TensoraxStudio — Environment Variables
# Copy this file to .env and fill in your own API keys.
# NEVER commit .env to the repo (it's in .gitignore).

# ── Gemini (Google AI) ──────────────────────────────────────────
# Used for: image analysis, chat, image generation (Imagen), video (Veo)
TENSORAX_ANALYSIS_KEY=
TENSORAX_COPY_KEY=
TENSORAX_IMAGE_KEY=
TENSORAX_VIDEO_KEY=

# ── Anthropic (Claude) ──────────────────────────────────────────
# Used for: prompt generation pipeline (analysis + 9-shot prompts)
ANTHROPIC_API_KEY=

# ── OpenAI ──────────────────────────────────────────────────────
# Used for: DALL-E 3 image generation fallback
OPENAI_API_KEY=

# ── fal.ai ──────────────────────────────────────────────────────
# Used for: Seedance and Kling video generation
FAL_KEY=

# ── Google Cloud (Vertex AI) ────────────────────────────────────
# Used for: Imagen 3 image generation (backend only)
# Place your GCP service account JSON as tensorax-key.json in project root
# GOOGLE_APPLICATION_CREDENTIALS=./tensorax-key.json
